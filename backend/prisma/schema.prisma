generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                  String   @id // [Prov].[Kab].[Kec].[Kel].[RW].[RT]
  name                String
  subdomain          String
  config              Json?
  subscription_status String   @default("TRIAL") // 'TRIAL' | 'ACTIVE' | 'EXPIRED' | 'SUSPENDED'
  subscription_until  DateTime? 
  subscription_plan   String   @default("FREE")  // 'FREE' | 'PREMIUM'
  createdAt           DateTime @default(now())
  referral_code       String?  @unique
  referred_by         String?  // Referral code used during registration
  suspended_reason    String?
  
  users     User[]
  wargas    Warga[]
  roles     Role[]
  invoices  SubscriptionInvoice[]
}

model User {
  id          String   @id @default(uuid())
  tenant_id   String
  warga_id    String?  @unique
  role        String   // Legacy role name ('admin' | 'staff' | 'warga')
  role_id     String?
  scope       String   @default("RT") // Primary operational scope
  name        String
  email       String   @unique
  kontak      String?
  password    String?
  permissions Json?
  verification_status String @default("VERIFIED") // 'PENDING' | 'VERIFIED' | 'REJECTED'

  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  warga       Warga?   @relation(fields: [warga_id], references: [id])
  role_entity Role?    @relation(fields: [role_id], references: [id])

  @@index([tenant_id])
}

model Warga {
  id            String   @id @default(uuid())
  tenant_id     String
  scope         String   @default("RT") // 'RT' | 'PKK' | 'Dasa Wisma'
  nik           String
  nama          String
  kontak        String?
  alamat        String
  tempat_lahir  String?
  tanggal_lahir String?
  pendidikan    String?
  pekerjaan     String?
  jenis_kelamin String?
  agama         String?
  status_penduduk String? @default("Tetap") // 'Tetap' | 'Kontrak'
  status_rumah    String? @default("Dihuni") // 'Dihuni' | 'Kosong'
  url_kk        String?
  avatar        String?
  status_domisili   String? @default("Aktif") // 'Aktif' | 'Pindah' | 'Meninggal Dunia'
  alamat_pindah     String?
  tanggal_meninggal String?
  lokasi_makam      String?
  pj_tipe           String? @default("Luar") // 'Warga' | 'Luar'
  pj_warga_id       String?
  pj_nama           String?
  pj_kontak         String?
  verification_status String @default("VERIFIED") // 'PENDING' | 'VERIFIED' | 'REJECTED'
  deletedAt           DateTime?

  tenant        Tenant   @relation(fields: [tenant_id], references: [id])
  anggota       AnggotaKeluarga[]
  pengurus          Pengurus[]
  kehadirans        Kehadiran[]
  surat_pengantars  SuratPengantar[]
  pembayaran_iurans PembayaranIuran[]
  aset_dipinjam     Aset[] @relation("WargaPeminjam")
  aset_bookings     AsetBooking[]
  push_subscriptions PushSubscription[]
  aduan_usulans     AduanUsulan[]
  polling_votes     PollingVote[]
  user              User?

  @@unique([tenant_id, nik])
  @@index([tenant_id, scope])
  @@index([nik])
  @@index([deletedAt])
}

model AnggotaKeluarga {
  id            String   @id @default(uuid())
  tenant_id     String
  warga_id      String
  nik           String
  nama          String
  hubungan      String   // 'Istri' | 'Suami' | 'Anak' | 'Orang Tua' | 'Mertua' | 'Famili Lain'
  tempat_lahir  String?
  tanggal_lahir String?
  pendidikan    String?
  pekerjaan     String?
  deletedAt     DateTime?
  warga         Warga    @relation(fields: [warga_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, nik])
  @@index([tenant_id, warga_id])
  @@index([deletedAt])
}

model Pengaturan {
  id        String   @id @default(uuid())
  tenant_id String
  scope     String   @default("RT")
  key       String
  value     Json

  @@index([tenant_id, scope, key])
}

model Pengurus {
  id        String   @id @default(uuid())
  tenant_id String
  scope     String   @default("RT")
  warga_id  String
  jabatan   String
  periode   String
  status    String   @default("aktif") // 'aktif' | 'tidak aktif'
  deletedAt DateTime?

  warga     Warga    @relation(fields: [warga_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, scope, warga_id])
  @@index([deletedAt])
}

model Notulensi {
  id        String   @id @default(uuid())
  tenant_id String
  scope     String   @default("RT")
  judul     String
  tanggal   String
  tuan_rumah_id String?
  tuan_rumah String?
  lokasi    String?
  url_foto  String?
  konten    String
  agenda_id String?
  jam_mulai String?
  jam_selesai String?

  kehadirans Kehadiran[]

  @@index([tenant_id, scope, tanggal])
}

model Kehadiran {
  id           String    @id @default(uuid())
  tenant_id    String
  notulensi_id String
  warga_id     String
  status       String    // 'hadir' | 'izin' | 'sakit' | 'alfa'

  notulensi    Notulensi @relation(fields: [notulensi_id], references: [id], onDelete: Cascade)
  warga        Warga     @relation(fields: [warga_id], references: [id], onDelete: Cascade)
  
  @@index([tenant_id, notulensi_id, warga_id])
}

model PushSubscription {
  id        String   @id @default(uuid())
  warga_id  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  warga     Warga    @relation(fields: [warga_id], references: [id], onDelete: Cascade)

  @@index([warga_id])
}

model Aset {
  id             String   @id @default(uuid())
  tenant_id      String
  scope          String   @default("RT")
  nama_barang    String
  jumlah         Int
  kondisi        String   // 'baik' | 'rusak_ringan' | 'rusak_berat'
  foto_barang    String?
  tanggal_beli   String?
  harga_beli     Float?
  vendor         String?
  status_pinjam  String   @default("tersedia") // 'tersedia' | 'dipinjam'
  peminjam_id    String?
  petugas_id     String?
  tanggal_pinjam String?

  peminjam       Warga?   @relation("WargaPeminjam", fields: [peminjam_id], references: [id], onDelete: SetNull)
  bookings       AsetBooking[]

  @@index([tenant_id, scope])
}

model AsetBooking {
  id              String   @id @default(uuid())
  tenant_id       String
  aset_id         String
  warga_id        String
  tanggal_mulai   String
  tanggal_selesai String
  keperluan       String?
  status          String   @default("PENDING") // 'PENDING' | 'APPROVED' | 'REJECTED' | 'COMPLETED' | 'CANCELLED'
  catatan_admin   String?
  createdAt       DateTime @default(now())

  aset            Aset     @relation(fields: [aset_id], references: [id], onDelete: Cascade)
  warga           Warga    @relation(fields: [warga_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, aset_id, status])
}

model SuratPengantar {
  id          String   @id @default(uuid())
  tenant_id   String
  scope       String   @default("RT")
  warga_id    String
  jenis_surat String
  keperluan   String
  tanggal     String
  nomor_surat String?
  status      String   // 'proses' | 'selesai' | 'ditolak'
  deletedAt   DateTime?

  warga       Warga    @relation(fields: [warga_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, scope, warga_id, status])
  @@index([deletedAt])
}

model JadwalRonda {
  id               String   @id @default(uuid())
  tenant_id        String
  scope            String   @default("RT")
  tanggal          String
  regu             String
  warga_ids        String[]
  petugas_konsumsi String[]
  kehadiran_warga  String[]

  @@index([tenant_id, scope, tanggal])
}

model Agenda {
  id               String   @id @default(uuid())
  tenant_id        String
  scope            String   @default("RT")
  judul            String
  tanggal          String
  deskripsi        String
  butuh_pendanaan  Boolean  @default(false)
  nominal_biaya    Float?
  sumber_dana      String?  // 'Kas' | 'Iuran'
  peserta_ids      String[]
  is_semua_warga   Boolean  @default(false)
  is_terlaksana    Boolean  @default(false)
  laporan_kegiatan String?
  foto_dokumentasi String[]
  jenis_kegiatan   String?
  perlu_rapat      Boolean? @default(false)
  keterangan_tambahan String?
  tuan_rumah_id       String?
  tuan_rumah          String?
  lokasi              String?
  jam_mulai           String?
  jam_selesai         String?
  
  keuangan            Keuangan?
  
  @@index([tenant_id, scope, tanggal])
}

model Keuangan {
  id         String   @id @default(uuid())
  tenant_id  String
  scope      String   @default("RT")
  tipe       String   // 'pemasukan' | 'pengeluaran'
  kategori   String
  nominal    Float
  tanggal    String
  keterangan String
  url_bukti  String?
  deletedAt  DateTime?

  pembayaranIuranId String? @unique
  pembayaranIuran   PembayaranIuran? @relation(fields: [pembayaranIuranId], references: [id])

  agendaId          String? @unique
  agenda            Agenda? @relation(fields: [agendaId], references: [id])

  @@index([tenant_id, scope, tipe, kategori, tanggal])
  @@index([deletedAt])
}

model PembayaranIuran {
  id            String   @id @default(uuid())
  tenant_id     String
  scope         String   @default("RT")
  warga_id      String
  kategori      String
  periode_bulan Int[]
  periode_tahun Int
  nominal       Float
  tanggal_bayar String
  url_bukti     String?
  status        String   @default("PENDING") // 'PENDING' | 'VERIFIED' | 'REJECTED'
  alasan_penolakan String?
  deletedAt        DateTime?

  warga         Warga    @relation(fields: [warga_id], references: [id], onDelete: Cascade)
  keuangan      Keuangan?

  @@index([tenant_id, scope, warga_id, kategori, periode_tahun, status])
  @@index([deletedAt])
}

model Aktivitas {
  id        String   @id @default(uuid())
  tenant_id String
  scope     String   @default("RT")
  action    String
  details   String
  target_url String?
  timestamp Float

  @@index([tenant_id, scope, timestamp])
}

model Role {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String   // 'Admin', 'Sekretaris', 'Warga', etc.
  permissions Json?    // Standard permissions for this role: { [module]: { actions: string[], scope: 'all' | 'personal' } }
  
  users       User[]
  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  
  @@unique([tenant_id, name])
  @@index([tenant_id])
}

model Wilayah {
  id        String   @id
  parent_id String?
  name      String
  level     String   // 'provinsi' | 'kabkota' | 'kecamatan' | 'keldesa'

  @@index([parent_id, level])
}

model AduanUsulan {
  id            String   @id @default(uuid())
  tenant_id     String
  scope         String   @default("RT")
  warga_id      String
  tipe          String   // 'Aduan' | 'Usulan'
  judul         String
  deskripsi     String
  status        String   @default("Menunggu") // 'Menunggu' | 'Proses' | 'Selesai'
  tanggal       String
  foto_url      String?
  tanggapan     String?
  is_anonymous  Boolean  @default(false)
  
  warga         Warga    @relation(fields: [warga_id], references: [id], onDelete: Cascade)
  polling       Polling?

  @@index([tenant_id, scope, status, tipe])
}

model Polling {
  id              String   @id @default(uuid())
  tenant_id       String
  scope           String   @default("RT")
  aduan_usulan_id String   @unique
  pertanyaan      String
  status          String   @default("Aktif") // 'Aktif' | 'Selesai'
  tanggal_mulai   String
  tanggal_selesai String?
  
  aduan_usulan    AduanUsulan @relation(fields: [aduan_usulan_id], references: [id], onDelete: Cascade)
  opsi            PollingOpsi[]
  votes           PollingVote[]

  @@index([tenant_id, scope, status])
}

model PollingOpsi {
  id          String   @id @default(uuid())
  polling_id  String
  teks        String
  
  polling     Polling  @relation(fields: [polling_id], references: [id], onDelete: Cascade)
  votes       PollingVote[]
}

model PollingVote {
  id          String   @id @default(uuid())
  polling_id  String
  opsi_id     String
  warga_id    String
  
  polling     Polling    @relation(fields: [polling_id], references: [id], onDelete: Cascade)
  opsi        PollingOpsi @relation(fields: [opsi_id], references: [id], onDelete: Cascade)
  warga       Warga      @relation(fields: [warga_id], references: [id], onDelete: Cascade)

  @@unique([polling_id, warga_id])
}

model SubscriptionInvoice {
  id              String   @id @default(uuid())
  tenant_id       String
  invoice_number  String   @unique  // e.g. INV-2026-04-001
  unique_code     Int                // 3-digit auto-generated (100-999) added to total
  plan            String              // 'PREMIUM'
  pricePackageId  String?
  pricePackage    PricePackage? @relation(fields: [pricePackageId], references: [id])
  duration        Int      @default(1)
  duration_unit   String   @default("MONTH")
  base_amount     Float               // Base price before unique code
  total_amount    Float               // base_amount + unique_code
  status          String   @default("PENDING") // 'PENDING' | 'UPLOADED' | 'VERIFIED' | 'REJECTED' | 'EXPIRED'
  payment_proof   String?             // URL to uploaded proof of payment
  payment_method  String?             // 'BCA' | 'BRI' | 'MANDIRI' | 'GOPAY' | 'OVO' | 'GATEWAY'
  verified_by     String?             // Super Admin user ID who verified
  verified_at     DateTime?
  rejected_reason String?
  notes           String?
  createdAt       DateTime @default(now())
  expiresAt       DateTime            // Invoice expiry (24-48 hours)

  tenant          Tenant   @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, status])
  @@index([invoice_number])
}

model PricePackage {
  id                String   @id @default(uuid())
  name              String
  description       String?
  price             Float
  duration          Int      @default(1) // Number of units
  duration_unit     String   @default("MONTH") // 'WEEK' | 'MONTH'
  features          Json?    // Array of features
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  invoices          SubscriptionInvoice[]
}


model AffiliateReward {
  id              String   @id @default(uuid())
  referrer_tenant String              // Tenant ID yang mereferensikan
  referred_tenant String              // Tenant ID yang direferensikan
  reward_type     String   @default("EXTENSION") // 'DISCOUNT' | 'EXTENSION' | 'CREDIT'
  reward_value    Float               // e.g. 30 (days) for EXTENSION, or nominal for CREDIT
  status          String   @default("PENDING")   // 'PENDING' | 'CLAIMED' | 'EXPIRED'
  createdAt       DateTime @default(now())
  claimedAt       DateTime?

  @@index([referrer_tenant, status])
  @@index([referred_tenant])
}
