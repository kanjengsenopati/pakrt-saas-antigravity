generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                  String    @id
  name                String
  subdomain           String
  config              Json?
  subscription_plan   String    @default("FREE")
  subscription_status String    @default("TRIAL")
  subscription_until  DateTime?
  roles               Role[]
  users               User[]
  wargas              Warga[]
}

model User {
  id                  String  @id @default(uuid())
  tenant_id           String
  role                String
  name                String
  email               String  @unique
  kontak              String?
  password            String?
  permissions         Json?
  scope               String  @default("RT")
  warga_id            String? @unique
  role_id             String?
  verification_status String  @default("VERIFIED")
  role_entity         Role?   @relation(fields: [role_id], references: [id])
  tenant              Tenant  @relation(fields: [tenant_id], references: [id])
  warga               Warga?  @relation(fields: [warga_id], references: [id])

  @@index([tenant_id])
}

model Warga {
  id                  String             @id @default(uuid())
  tenant_id           String
  scope               String             @default("RT")
  nik                 String
  nama                String
  kontak              String?
  alamat              String
  tempat_lahir        String?
  tanggal_lahir       String?
  pendidikan          String?
  jenis_kelamin       String?
  agama               String?
  status_penduduk     String?            @default("Tetap")
  status_rumah        String?            @default("Dihuni")
  url_kk              String?
  avatar              String?
  pekerjaan           String?
  alamat_pindah       String?
  lokasi_makam        String?
  status_domisili     String?            @default("Aktif")
  tanggal_meninggal   String?
  pj_kontak           String?
  pj_nama             String?
  pj_tipe             String?            @default("Luar")
  pj_warga_id         String?
  verification_status String             @default("VERIFIED")
  deletedAt           DateTime?
  aduan_usulans       AduanUsulan[]
  anggota             AnggotaKeluarga[]
  aset_dipinjam       Aset[]             @relation("WargaPeminjam")
  kehadirans          Kehadiran[]
  pembayaran_iurans   PembayaranIuran[]
  pengurus            Pengurus[]
  polling_votes       PollingVote[]
  push_subscriptions  PushSubscription[]
  surat_pengantars    SuratPengantar[]
  user                User?
  tenant              Tenant             @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, nik])
  @@index([tenant_id, scope])
  @@index([nik])
  @@index([deletedAt])
}

model AnggotaKeluarga {
  id            String    @id @default(uuid())
  tenant_id     String
  warga_id      String
  nik           String
  nama          String
  hubungan      String
  tempat_lahir  String?
  tanggal_lahir String?
  pendidikan    String?
  pekerjaan     String?
  deletedAt     DateTime?
  warga         Warga     @relation(fields: [warga_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, nik])
  @@index([tenant_id, warga_id])
  @@index([deletedAt])
}

model Pengaturan {
  id        String @id @default(uuid())
  tenant_id String
  scope     String @default("RT")
  key       String
  value     Json

  @@index([tenant_id, scope, key])
}

model Pengurus {
  id        String    @id @default(uuid())
  tenant_id String
  scope     String    @default("RT")
  warga_id  String
  jabatan   String
  periode   String
  status    String    @default("aktif")
  deletedAt DateTime?
  warga     Warga     @relation(fields: [warga_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, scope, warga_id])
  @@index([deletedAt])
}

model Notulensi {
  id            String      @id @default(uuid())
  tenant_id     String
  scope         String      @default("RT")
  judul         String
  tanggal       String
  konten        String
  lokasi        String?
  tuan_rumah    String?
  tuan_rumah_id String?
  url_foto      String?
  agenda_id     String?
  jam_mulai     String?
  jam_selesai   String?
  kehadirans    Kehadiran[]

  @@index([tenant_id, scope, tanggal])
}

model Kehadiran {
  id           String    @id @default(uuid())
  tenant_id    String
  notulensi_id String
  warga_id     String
  status       String
  notulensi    Notulensi @relation(fields: [notulensi_id], references: [id], onDelete: Cascade)
  warga        Warga     @relation(fields: [warga_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, notulensi_id, warga_id])
}

model PushSubscription {
  id        String   @id @default(uuid())
  warga_id  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  warga     Warga    @relation(fields: [warga_id], references: [id], onDelete: Cascade)

  @@index([warga_id])
}

model Aset {
  id             String  @id @default(uuid())
  tenant_id      String
  scope          String  @default("RT")
  nama_barang    String
  jumlah         Int
  kondisi        String
  foto_barang    String?
  harga_beli     Float?
  peminjam_id    String?
  petugas_id     String?
  status_pinjam  String  @default("tersedia")
  tanggal_beli   String?
  tanggal_pinjam String?
  vendor         String?
  peminjam       Warga?  @relation("WargaPeminjam", fields: [peminjam_id], references: [id])

  @@index([tenant_id, scope])
}

model SuratPengantar {
  id          String    @id @default(uuid())
  tenant_id   String
  scope       String    @default("RT")
  warga_id    String
  jenis_surat String
  keperluan   String
  tanggal     String
  nomor_surat String?
  status      String
  deletedAt   DateTime?
  warga       Warga     @relation(fields: [warga_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, scope, warga_id, status])
  @@index([deletedAt])
}

model JadwalRonda {
  id               String   @id @default(uuid())
  tenant_id        String
  scope            String   @default("RT")
  tanggal          String
  regu             String
  warga_ids        String[]
  petugas_konsumsi String[]
  kehadiran_warga  String[]

  @@index([tenant_id, scope, tanggal])
}

model Agenda {
  id                  String   @id @default(uuid())
  tenant_id           String
  scope               String   @default("RT")
  judul               String
  tanggal             String
  deskripsi           String
  butuh_pendanaan     Boolean  @default(false)
  foto_dokumentasi    String[]
  is_terlaksana       Boolean  @default(false)
  laporan_kegiatan    String?
  nominal_biaya       Float?
  peserta_ids         String[]
  sumber_dana         String?
  jenis_kegiatan      String?
  keterangan_tambahan String?
  perlu_rapat         Boolean? @default(false)
  is_semua_warga      Boolean  @default(false)
  lokasi              String?
  tuan_rumah          String?
  tuan_rumah_id       String?
  jam_mulai           String?
  jam_selesai         String?

  @@index([tenant_id, scope, tanggal])
}

model Keuangan {
  id                String           @id @default(uuid())
  tenant_id         String
  scope             String           @default("RT")
  tipe              String
  kategori          String
  nominal           Float
  tanggal           String
  keterangan        String
  url_bukti         String?
  pembayaranIuranId String?          @unique
  deletedAt         DateTime?
  pembayaranIuran   PembayaranIuran? @relation(fields: [pembayaranIuranId], references: [id])

  @@index([tenant_id, scope, tipe, kategori, tanggal])
  @@index([deletedAt])
}

model PembayaranIuran {
  id               String    @id @default(uuid())
  tenant_id        String
  warga_id         String
  kategori         String
  periode_bulan    Int[]
  periode_tahun    Int
  nominal          Float
  tanggal_bayar    String
  url_bukti        String?
  scope            String    @default("RT")
  alasan_penolakan String?
  status           String    @default("PENDING")
  deletedAt        DateTime?
  keuangan         Keuangan?
  warga            Warga     @relation(fields: [warga_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, scope, warga_id, kategori, periode_tahun, status])
  @@index([deletedAt])
}

model Aktivitas {
  id        String @id @default(uuid())
  tenant_id String
  scope     String @default("RT")
  action    String
  details   String
  timestamp Float

  @@index([tenant_id, scope, timestamp])
}

model Role {
  id          String @id @default(uuid())
  tenant_id   String
  name        String
  permissions Json?
  tenant      Tenant @relation(fields: [tenant_id], references: [id])
  users       User[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
}

model Wilayah {
  id        String  @id
  parent_id String?
  name      String
  level     String

  @@index([parent_id, level])
}

model AduanUsulan {
  id           String   @id @default(uuid())
  tenant_id    String
  scope        String   @default("RT")
  warga_id     String
  tipe         String
  judul        String
  deskripsi    String
  status       String   @default("Menunggu")
  tanggal      String
  foto_url     String?
  tanggapan    String?
  is_anonymous Boolean  @default(false)
  warga        Warga    @relation(fields: [warga_id], references: [id], onDelete: Cascade)
  polling      Polling?

  @@index([tenant_id, scope, status, tipe])
}

model Polling {
  id              String        @id @default(uuid())
  tenant_id       String
  scope           String        @default("RT")
  aduan_usulan_id String        @unique
  pertanyaan      String
  status          String        @default("Aktif")
  tanggal_mulai   String
  tanggal_selesai String?
  aduan_usulan    AduanUsulan   @relation(fields: [aduan_usulan_id], references: [id], onDelete: Cascade)
  opsi            PollingOpsi[]
  votes           PollingVote[]

  @@index([tenant_id, scope, status])
}

model PollingOpsi {
  id         String        @id @default(uuid())
  polling_id String
  teks       String
  polling    Polling       @relation(fields: [polling_id], references: [id], onDelete: Cascade)
  votes      PollingVote[]
}

model PollingVote {
  id         String      @id @default(uuid())
  polling_id String
  opsi_id    String
  warga_id   String
  opsi       PollingOpsi @relation(fields: [opsi_id], references: [id], onDelete: Cascade)
  polling    Polling     @relation(fields: [polling_id], references: [id], onDelete: Cascade)
  warga      Warga       @relation(fields: [warga_id], references: [id], onDelete: Cascade)

  @@unique([polling_id, warga_id])
}
